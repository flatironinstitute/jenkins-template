pipeline {
  agent none
  options {
    disableConcurrentBuilds()
    buildDiscarder(logRotator(numToKeepStr: '8', daysToKeepStr: '20'))
    timeout(time: 1, unit: 'HOURS')
  }
  stages {
    stage('cpu') {
      steps {
        buildPod(context: 'example') {
          sh 'nproc'
          sh 'g++ -v'
          sh 'pip3 -V'
        }
      }
    }
    stage('cuda') {
      steps {
        buildPod(context: 'example', dockerfile: 'Dockerfile-cuda') {
          sh 'nproc'
          sh 'nvidia-smi'
        }
      }
    }
  }
}
